# Polaczenie do bazy SQL Server Subiekta GT (odczyt do testow GtBridge / sync produktow)
GT_SQL_HOST=192.168.0.200
GT_SQL_PORT=49951
GT_SQL_DATABASE=Z_KAJTEK_IdeaERP
GT_SQL_USER=sa
GT_SQL_PASSWORD=

# Job rozjazdow GT vs WMS (services/rozjazdy.js) - scala kopie WMS K4 do stanu GT.
# ROZJAZDY_INTERWAL_MIN - co ile minut przebieg (domyslnie 10). K4 = zywa sprzedaz,
#   wiec krotszy interwal = mniejsze okno rozjazdu, kosztem czestszych zapytan do GT.
ROZJAZDY_INTERWAL_MIN=10

# Srodowisko testowe - szary pasek "TESTOWY" na Zebrze/desktopie (public/shared/auth.js),
# zeby nie pomylic Maca z produkcja. Ustaw WMS_TESTOWY=1 TYLKO na maszynie testowej.
# Produkcja: NIE ustawiaj (domyslnie brak paska).
# WMS_TESTOWY=1

# DATA ODCIECIA dokumentow do stref (services/gt-dokumenty.js) - USTAW NA DZIEN WDROZENIA.
# Dokumenty starsze nie licza sie do dostaw/zwrotow/przywozek "do rozlozenia".
#
# Po co: przed wdrozeniem palety byly rozkladane poza nowym obiegiem (MM w Subiekcie albo
# dwukrok /lok -> /mm), wiec nie maja podpisu dokumentem i dla naszego rachunku wygladaja na
# nierozlozone. Pomiar 17.07.2026: bez odciecia 228 dostaw pokazuje sie jako widmo, kazde
# zjadajac CALY stan K4 i wypychajac polke do zera (np. NERCHIELIT10: "rozloz 2822" przy
# 2822 szt. na magazynie, polka 0).
#
# STALA WYGASA: okno dostaw to 90 dni, wiec ~90 dni po wdrozeniu mozna ja usunac razem
# z warunkiem w kodzie.
WMS_DOKUMENTY_OD=2026-07-18

# Okno dla zwrotow i przywozek w dniach (domyslnie 14). Dostawy maja na sztywno 90 -
# to inne zjawisko: duze, rzadkie, FZ bywa starsza od przyjecia.
# WMS_OKNO_DROBNICA_DNI=14

# Backup bazy WMS (services/backup.js)
# WMS_BACKUP_MIRROR - drugie miejsce na kopie (drugi dysk / chmura / sciezka sieciowa).
#   Puste = tylko lokalnie (db/backups/). Ustaw przy wdrozeniu na Windows.
WMS_BACKUP_MIRROR=
# WMS_BACKUP_DIR - nadpisz katalog kopii (domyslnie db/backups/)
# WMS_BACKUP_DISABLED=1 - wylacz backup (np. w testach)
